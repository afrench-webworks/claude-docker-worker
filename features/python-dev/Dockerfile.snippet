# Ensure python3 and pip are present (included in base, but be explicit)
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

# Python development tools
RUN pip3 install --break-system-packages \
    pytest \
    black \
    ruff \
    mypy \
    ipython \
    virtualenv \
    poetry
