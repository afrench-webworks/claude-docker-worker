repos:
  - owner/repo-name
  # - org/another-repo

authorized_users:
  - your-github-username           # Only respond to mentions from these users

label: claude-task                 # Issues must have this label to be picked up by the issue worker
mention: "@dockworker"             # Comment monitor only responds to comments containing this mention
bot_signature: "— 🚢 Claude Dockworker"
git_bot_name: "claude-docker-worker"
git_bot_email: "claude-docker-worker@noreply.github.com"

# Issue worker time window — hours (24h format, container timezone)
# Omit both to run 24/7 (default). Set both to restrict issue processing.
# issue_work_window_start: 0
# issue_work_window_end: 8

# GitHub App identity (optional — omit to post as your personal account)
# Installations are auto-discovered — just install the app on your accounts/orgs.
# app_id: "12345"

# Plugins — Claude Code plugins are auto-discovered from
# ~/.claude/plugins/installed_plugins.json (on the claude-config volume).
# Install plugins on your host machine, then restart the container.
# Alternatively, volume-mount a host plugin directory into the container.
